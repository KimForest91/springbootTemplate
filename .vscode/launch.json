{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Spring Boot (default)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.example.backend.BackendApplication",
            "projectName": "backend",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot (dev)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.example.backend.BackendApplication",
            "projectName": "backend",
            "args": "--spring.profiles.active=dev",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot (prod)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.example.backend.BackendApplication",
            "projectName": "backend",
            "args": "--spring.profiles.active=prod",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}