{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradle build (skip test)",
            "type": "shell",
            "command": "./gradlew",
            "args": ["build", "-x", "test"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "spring boot run",
            "type": "shell",
            "command": "./gradlew",
            "args": ["bootRun"],
            "problemMatcher": []
        },
        {
            "label": "spring boot run (dev)",
            "type": "shell",
            "command": "./gradlew",
            "args": ["bootRun", "--args=--spring.profiles.active=dev"],
            "problemMatcher": []
        }
    ]
}